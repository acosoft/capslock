#!/usr/bin/env php
<?php
declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Symfony\Component\Console\Application;

$application = new Application('Event Loader', '0.1.0');

// Bootstrap minimal test doubles and register the EventLoaderCommand so `app:event-loader` works
// without a full Symfony kernel.
try {
    // create simple implementations for local testing
    $logger = new \App\Logger\StdoutLogger();
    $registry = new \App\TestDoubles\InMemoryEventSourceRegistry();
    // use random event source client for testing
    $client = new \App\TestDoubles\RandomEventSourceClient();
    $storage = new \App\TestDoubles\InMemoryEventStorage();
    $cursor = new \App\TestDoubles\InMemorySourceCursorStore();
    // prefer Redis-backed lease manager if Predis is available and REDIS_DSN is set
    $redisDsn = getenv('REDIS_DSN') ?: 'tcp://redis:6379';
    try {
        $predis = new \Predis\Client($redisDsn);
        $lease = new \App\Adapter\RedisSourceLeaseManager($predis);
        // Startup bootstrap per spec.md: ensure `source:*` keys exist or perform idempotent bootstrap
        $bootstrapLockKey = 'lock:sources';
        $bootstrapTtlMs = 10000; // 10s
        // If no source:* keys exist, try to acquire bootstrap lock and populate source:{name}
        while (true) {
            try {
                $existing = $predis->keys('source:*');
            } catch (Throwable $e) {
                // if keys command fails, bail out of bootstrap and continue; loader requires Redis anyway
                break;
            }
            if (is_array($existing) && count($existing) > 0) {
                fwrite(STDOUT, "Bootstrap: found existing source:* keys, skipping bootstrap\n");
                break; // already bootstrapped
            }
            fwrite(STDOUT, "Bootstrap: no source:* keys found, attempting to acquire lock:sources\n");
            $ownerToken = 'bootstrap_' . bin2hex(random_bytes(6));
            $script = "local r = redis.call('set', KEYS[1], ARGV[1], 'PX', ARGV[2], 'NX') if r then return r else return nil end";
            $res = null;
            try {
                $res = $predis->eval($script, 1, $bootstrapLockKey, $ownerToken, (string)$bootstrapTtlMs);
            } catch (Throwable $e) {
                fwrite(STDOUT, "Bootstrap: eval failed when attempting lock acquisition: " . $e->getMessage() . "\n");
                // failed to eval script - retry after sleep
            }
            if ($res !== null) {
                fwrite(STDOUT, "Bootstrap: acquired lock:sources, writing source entries to Redis\n");
                // acquired bootstrap lock - perform idempotent writes
                try {
                    $sources = $registry->getSources();
                    foreach ($sources as $name => $meta) {
                        $predis->set('source:' . $name, json_encode($meta, JSON_THROW_ON_ERROR));
                    }
                    fwrite(STDOUT, "Bootstrap: wrote " . count($sources) . " sources to Redis\n");
                } catch (Throwable $e) {
                    fwrite(STDERR, "Bootstrap write failed: " . $e->getMessage() . PHP_EOL);
                }
                // release the bootstrap lock
                try {
                    $predis->del($bootstrapLockKey);
                    fwrite(STDOUT, "Bootstrap: released lock:sources\n");
                } catch (Throwable $e) {
                    // ignore
                }
                break;
            }
            // failed to acquire lock, sleep 10s and retry per spec
            fwrite(STDOUT, "Bootstrap: lock:sources unavailable; sleeping 10000ms before retrying\n");
            usleep(10000000);
        }
    } catch (\Throwable $e) {
        fwrite(STDERR, "Redis lease manager initialization failed: " . $e->getMessage() . PHP_EOL);
        exit(1);
    }
    $clock = new \App\TestDoubles\SystemClock();

    $loader = new \App\Service\EventLoader(
        $registry,
        $client,
        $storage,
        $cursor,
        $lease,
        $clock,
        $logger
    );

    $application->add(new \App\Command\EventLoaderCommand($loader));

    $application->run();
} catch (Throwable $e) {
    fwrite(STDERR, $e->getMessage() . PHP_EOL);
    exit(1);
}
